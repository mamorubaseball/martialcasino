---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const pageTitle = "米国株 銘柄一覧";
const pageDescription = "AIスコア・リアルタイム株価分析をベースにした米国株の注目銘柄一覧です。";

const stocks = [
  {
    ticker: 'nvda',
    name: 'NVIDIA',
    fullname: 'NVIDIA Corporation',
    tags: ['半導体', 'AI', 'データセンター'],
    price: '1,024.86',
    change: '+34.21',
    changePercent: '+3.45%',
    isPositive: true,
    aiScore: '92.5',
    aiVerdict: '非常に強い買い',
    overview: 'GPUの設計・製造を行うリーディングカンパニー。AI、データセンター、自動運転などで圧倒的な市場シェアを握る。',
    sparkline: 'M0 20 L10 18 L20 22 L30 12 L40 15 L50 8 L60 14 L70 5 L80 12 L90 2 L100 4'
  },
  {
    ticker: 'pltr',
    name: 'Palantir',
    fullname: 'Palantir Technologies Inc.',
    tags: ['ソフトウェア', 'AI', 'ビッグデータ'],
    price: '24.50',
    change: '+1.12',
    changePercent: '+4.78%',
    isPositive: true,
    aiScore: '87.4',
    aiVerdict: '強い買い',
    overview: '巨大データ分析ソフトウェア企業。民間向けのAIプラットフォーム「AIP」需要が驚異的なペースで急拡大している。',
    sparkline: 'M0 25 L20 23 L40 18 L60 12 L80 15 L100 5'
  },
  {
    ticker: 'avgo',
    name: 'Broadcom',
    fullname: 'Broadcom Inc.',
    tags: ['半導体', 'インフラ', '通信'],
    price: '1,420.10',
    change: '-12.50',
    changePercent: '-0.87%',
    isPositive: false,
    aiScore: '84.1',
    aiVerdict: '買い',
    overview: '半導体およびインフラソフトウェア大手。カスタムAI ASICチップの設計能力に強みを持ち、ネットワーク機器で覇権を握る。',
    sparkline: 'M0 8 L20 12 L40 15 L60 22 L80 20 L100 25'
  },
  {
    ticker: 'tsla',
    name: 'Tesla',
    fullname: 'Tesla, Inc.',
    tags: ['EV', '自動運転', '蓄電池'],
    price: '175.40',
    change: '+2.10',
    changePercent: '+1.21%',
    isPositive: true,
    aiScore: '81.6',
    aiVerdict: '中立',
    overview: 'EVおよび定置型蓄電池大手。完全自動運転ソフト(FSD)の急速な進化とロボタクシー構想での新たな成長フェーズを目指す。',
    sparkline: 'M0 25 L20 22 L40 28 L60 18 L80 15 L100 12'
  },
  {
    ticker: 'msft',
    name: 'Microsoft',
    fullname: 'Microsoft Corporation',
    tags: ['ソフトウェア', 'クラウド', 'AI'],
    price: '425.20',
    change: '+3.40',
    changePercent: '+0.81%',
    isPositive: true,
    aiScore: '79.8',
    aiVerdict: '買い',
    overview: 'WindowsやOfficeに加え、クラウド「Azure」を展開。OpenAIへの戦略的投資を通じて、コパイロットAIのビジネス実装を独走。',
    sparkline: 'M0 20 L20 18 L40 22 L60 15 L80 12 L100 8'
  }
];

const allTags = Array.from(new Set(stocks.flatMap(s => s.tags)));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${pageTitle} - ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body>
		<Header />
		
		<main class="stocks-main fade-in">
			<!-- Breadcrumbs -->
			<nav class="breadcrumb">
				<a href="/">トップ</a> &gt; <span class="current">銘柄一覧</span>
			</nav>

			<!-- Hero Header -->
			<div class="stocks-hero">
				<div class="glow-sphere"></div>
				<h1 class="hero-title">米国株 銘柄一覧</h1>
				<p class="hero-desc">AIスコア評価とファンダメンタルズ分析に基づく、現在カバーしている主要銘柄一覧です。</p>
			</div>

			<!-- Search & Filter Area -->
			<div class="filter-section glass-card">
				<div class="search-box">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-icon">
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
					<input type="text" id="stock-search" placeholder="銘柄名、ティッカーを入力..." />
				</div>
				<div class="tag-filters">
					<button class="tag-btn active" data-tag="all">すべて</button>
					{allTags.map(tag => (
						<button class="tag-btn" data-tag={tag}>{tag}</button>
					))}
				</div>
			</div>

			<!-- Grid List -->
			<div class="stocks-grid" id="stocks-container">
				{stocks.map(stock => (
					<div class="stock-card glass-card" data-name={stock.name.toLowerCase()} data-ticker={stock.ticker.toLowerCase()} data-tags={stock.tags.join(',')}>
						<div class="card-glow"></div>
						<div class="card-header">
							<div>
								<span class="ticker-badge">{stock.ticker.toUpperCase()}</span>
								<h2 class="stock-name">{stock.name}</h2>
								<p class="stock-fullname">{stock.fullname}</p>
							</div>
							<div class="score-badge-wrapper">
								<div class="score-ring-bg">
									<span class="score-num">{stock.aiScore}</span>
									<span class="score-label">AI SCORE</span>
								</div>
							</div>
						</div>

						<div class="tags-container">
							{stock.tags.map(tag => (
								<span class="tag-item">{tag}</span>
							))}
						</div>

						<p class="stock-overview">{stock.overview}</p>

						<div class="metrics-row">
							<div class="metric-col">
								<span class="metric-label">現在値</span>
								<span class="metric-value">${stock.price}</span>
							</div>
							<div class="metric-col">
								<span class="metric-label">前日比</span>
								<span class={`metric-value ${stock.isPositive ? 'pos' : 'neg'}`}>
									{stock.changePercent}
								</span>
							</div>
							<div class="metric-col">
								<span class="metric-label">AI診断</span>
								<span class={`verdict-val ${stock.isPositive ? 'pos' : 'neg'}`}>{stock.aiVerdict}</span>
							</div>
						</div>

						<div class="sparkline-wrapper">
							<svg class="sparkline" viewBox="0 0 100 30">
								<path d={stock.sparkline} fill="none" stroke={stock.isPositive ? 'var(--positive)' : 'var(--negative)'} stroke-width="2" stroke-linecap="round"/>
							</svg>
						</div>

						<div class="card-actions">
							<a href={`/stock/${stock.ticker}`} class="action-btn">詳細分析を見る &rarr;</a>
						</div>
					</div>
				))}
			</div>
		</main>

		<Footer />

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('stock-search');
				const tagButtons = document.querySelectorAll('.tag-btn');
				const stockCards = document.querySelectorAll('.stock-card');
				
				let activeTag = 'all';
				let searchQuery = '';

				function filterStocks() {
					stockCards.forEach(card => {
						const name = card.dataset.name || '';
						const ticker = card.dataset.ticker || '';
						const tags = (card.dataset.tags || '').split(',');

						const matchesSearch = name.includes(searchQuery) || ticker.includes(searchQuery);
						const matchesTag = activeTag === 'all' || tags.includes(activeTag);

						if (matchesSearch && matchesTag) {
							card.style.display = 'flex';
							card.style.opacity = '1';
							card.style.transform = 'scale(1)';
						} else {
							card.style.display = 'none';
							card.style.opacity = '0';
							card.style.transform = 'scale(0.95)';
						}
					});
				}

				if (searchInput) {
					searchInput.addEventListener('input', (e) => {
						searchQuery = e.target.value.toLowerCase().trim();
						filterStocks();
					});
				}

				tagButtons.forEach(btn => {
					btn.addEventListener('click', () => {
						tagButtons.forEach(b => b.classList.remove('active'));
						btn.classList.add('active');
						activeTag = btn.dataset.tag || 'all';
						filterStocks();
					});
				});
			});
		</script>
	</body>
</html>

<style>
	:root {
		--positive: #00ff87;
		--negative: #ff007f;
	}

	.stocks-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		position: relative;
	}

	.breadcrumb {
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-bottom: 2rem;
	}
	.breadcrumb a {
		color: var(--text-secondary);
		text-decoration: none;
	}
	.breadcrumb a:hover {
		color: var(--accent-light);
	}

	/* Hero Header */
	.stocks-hero {
		position: relative;
		padding: 3rem 0;
		text-align: center;
		margin-bottom: 3rem;
		overflow: hidden;
	}
	.glow-sphere {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 400px;
		height: 100px;
		background: radial-gradient(circle, rgba(0, 242, 254, 0.15) 0%, transparent 70%);
		filter: blur(40px);
		z-index: -1;
	}
	.hero-title {
		font-family: var(--font-display);
		font-size: 3rem;
		font-weight: 900;
		background: linear-gradient(135deg, #ffffff 60%, var(--accent-light) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}
	.hero-desc {
		font-size: 1.1rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 auto;
	}

	/* Filter Section */
	.filter-section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: 1.8rem;
		margin-bottom: 3rem;
	}
	.search-box {
		position: relative;
		width: 100%;
	}
	.search-icon {
		position: absolute;
		left: 1.2rem;
		top: 50%;
		transform: translateY(-50%);
		width: 20px;
		height: 20px;
		color: var(--text-muted);
	}
	.search-box input {
		width: 100%;
		padding: 1rem 1rem 1rem 3.2rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		color: #ffffff;
		font-size: 1rem;
		transition: all 0.3s ease;
	}
	.search-box input:focus {
		outline: none;
		border-color: var(--accent);
		background: rgba(255, 255, 255, 0.05);
		box-shadow: 0 0 15px rgba(0, 242, 254, 0.15);
	}
	.tag-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}
	.tag-btn {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-secondary);
		padding: 0.5rem 1.2rem;
		border-radius: 99px;
		cursor: pointer;
		font-size: 0.9rem;
		transition: all 0.2s ease;
	}
	.tag-btn:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.2);
		color: #ffffff;
	}
	.tag-btn.active {
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
		border-color: var(--accent);
		color: #ffffff;
		box-shadow: 0 0 10px var(--accent-glow);
	}

	/* Grid & Cards */
	.stocks-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: 2rem;
	}
	.stock-card {
		position: relative;
		padding: 2.2rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 400px;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.stock-card:hover {
		transform: translateY(-5px);
		border-color: rgba(0, 242, 254, 0.2);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 242, 254, 0.05);
	}
	.card-glow {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at top right, rgba(0, 242, 254, 0.02) 0%, transparent 60%);
		pointer-events: none;
		border-radius: inherit;
	}
	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.2rem;
	}
	.ticker-badge {
		font-family: var(--font-display);
		font-size: 0.8rem;
		font-weight: 800;
		color: var(--accent-light);
		background: rgba(0, 242, 254, 0.08);
		border: 1px solid rgba(0, 242, 254, 0.2);
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		display: inline-block;
		margin-bottom: 0.5rem;
		letter-spacing: 0.05em;
	}
	.stock-name {
		font-family: var(--font-display);
		font-size: 1.8rem;
		font-weight: 800;
		color: #ffffff;
		line-height: 1.2;
	}
	.stock-fullname {
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-top: 0.2rem;
	}
	.score-badge-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.score-ring-bg {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.02);
		border: 2px solid rgba(0, 242, 254, 0.2);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		box-shadow: 0 0 10px rgba(0, 242, 254, 0.1);
	}
	.score-num {
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--accent-light);
	}
	.score-label {
		font-size: 0.55rem;
		color: var(--text-muted);
		font-weight: 700;
		letter-spacing: 0.05em;
	}

	.tags-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.2rem;
	}
	.tag-item {
		font-size: 0.75rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 0.25rem 0.6rem;
		border-radius: 6px;
		color: var(--text-secondary);
	}

	.stock-overview {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.5;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	/* Metrics */
	.metrics-row {
		display: flex;
		justify-content: space-between;
		background: rgba(255, 255, 255, 0.01);
		border: 1px solid rgba(255, 255, 255, 0.04);
		border-radius: 12px;
		padding: 1rem;
		margin-bottom: 1.5rem;
	}
	.metric-col {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.metric-label {
		font-size: 0.75rem;
		color: var(--text-muted);
	}
	.metric-value {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 700;
		color: #ffffff;
	}
	.metric-value.pos, .verdict-val.pos {
		color: var(--positive);
	}
	.metric-value.neg, .verdict-val.neg {
		color: var(--negative);
	}
	.verdict-val {
		font-size: 0.95rem;
		font-weight: 800;
	}

	/* Sparkline */
	.sparkline-wrapper {
		height: 35px;
		margin-bottom: 1.5rem;
		opacity: 0.8;
	}
	.sparkline {
		width: 100%;
		height: 100%;
	}

	/* Action Button */
	.card-actions {
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding-top: 1.2rem;
		display: flex;
		justify-content: center;
	}
	.action-btn {
		width: 100%;
		text-align: center;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: #ffffff;
		text-decoration: none;
		padding: 0.75rem;
		border-radius: 8px;
		font-size: 0.95rem;
		font-weight: 600;
		transition: all 0.2s ease;
	}
	.action-btn:hover {
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
		border-color: var(--accent);
		box-shadow: 0 0 15px var(--accent-glow);
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.2rem;
		}
		.filter-section {
			padding: 1.2rem;
		}
		.tag-filters {
			gap: 0.5rem;
		}
		.tag-btn {
			padding: 0.4rem 1rem;
			font-size: 0.85rem;
		}
		.stocks-grid {
			grid-template-columns: 1fr;
		}
		.stock-card {
			padding: 1.5rem;
		}
	}
</style>
