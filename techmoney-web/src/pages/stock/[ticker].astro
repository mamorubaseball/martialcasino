const stock = stocksDb[ticker as keyof typeof stocksDb] || stocksDb.nvda;

// Fetch blog articles matching the ticker or name
const allPosts = await getCollection('blog');
const relatedPosts = allPosts.filter(post => 
  post.data.title.toLowerCase().includes(stock.name.toLowerCase()) ||
  post.body?.toLowerCase().includes(stock.name.toLowerCase())
).slice(0, 3);

// Fallback logic if no posts found: show general latest posts
const displayedPosts = relatedPosts.length > 0 ? relatedPosts : allPosts.slice(0, 3);

// Calculations for custom SVG pentagon radar chart
// Center = (50, 50), Max Radius = 40
// Angles (rad): 90deg, 162deg, 234deg, 306deg, 18deg
const computeRadarPoints = (score: typeof stock.scoreMeta) => {
  const rMax = 38;
  const cx = 50;
  const cy = 50;
  
  // Ratios (0.0 to 1.0)
  const g = score.growth / 100;
  const p = score.profitability / 100;
  const m = score.momentum / 100;
  const v = score.value / 100;
  const h = score.health / 100;
  
  // Point 1: Top (Growth) - 270 deg (in SVG, Y goes down, so Y = 50 - r)
  const x1 = cx;
  const y1 = cy - g * rMax;
  
  // Point 2: Right Top (Profitability) - 342 deg (in Y-down, Y = 50 - r * sin(18deg), X = 50 + r * cos(18deg))
  const x2 = cx + p * rMax * Math.cos(18 * Math.PI / 180);
  const y2 = cy - p * rMax * Math.sin(18 * Math.PI / 180);
  
  // Point 3: Right Bottom (Momentum) - 54 deg (Y = 50 + r * sin(54deg), X = 50 + r * cos(54deg))
  const x3 = cx + m * rMax * Math.cos(54 * Math.PI / 180);
  const y3 = cy + m * rMax * Math.sin(54 * Math.PI / 180);
  
  // Point 4: Left Bottom (Value) - 126 deg (Y = 50 + r * sin(54deg), X = 50 - r * cos(54deg))
  const x4 = cx - v * rMax * Math.cos(54 * Math.PI / 180);
  const y4 = cy + v * rMax * Math.sin(54 * Math.PI / 180);
  
  // Point 5: Left Top (Health) - 198 deg (Y = 50 - r * sin(18deg), X = 50 - r * cos(18deg))
  const x5 = cx - h * rMax * Math.cos(18 * Math.PI / 180);
  const y5 = cy - h * rMax * Math.sin(18 * Math.PI / 180);
  
  return `${x1},${y1} ${x2},${y2} ${x3},${y3} ${x4},${y4} ${x5},${y5}`;
};

const radarPoints = computeRadarPoints(stock.scoreMeta);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${stock.name} (${ticker.toUpperCase()}) - ${SITE_TITLE}`} description={stock.overview} />
	</head>
	<body>
		<Header />
		
		<main class="stock-main fade-in">
			<!-- Breadcrumb -->
			<div class="breadcrumb">
				<a href="/">トップ</a> &gt; <a href="/ranking/ai">銘柄一覧</a> &gt; <span class="current">{stock.name}</span>
			</div>

			<!-- Stock Main Header Panel -->
			<div class="glass-card stock-header-panel">
				<div class="stock-title-section">
					<div class="stock-brand">
						<!-- Custom Brand Logo Placeholder -->
						<div class="brand-logo-circle">
							<span class="logo-char">{stock.name.charAt(0)}</span>
						</div>
						<div class="brand-text">
							<h1 class="brand-name">{stock.name}</h1>
							<span class="brand-ticker-exchange">{ticker.toUpperCase()} ｜ {stock.exchange}</span>
						</div>
					</div>
					<div class="stock-tags">
						{stock.tags.map(tag => <span class="stock-tag">{tag}</span>)}
					</div>
					<div class="stock-actions">
						<button class="btn btn-outline action-btn"><span class="star-icon">☆</span> ウォッチリストに追加</button>
						<button class="btn btn-outline action-btn-icon" aria-label="Share">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
								<circle cx="18" cy="5" r="3"></circle>
								<circle cx="6" cy="12" r="3"></circle>
								<circle cx="18" cy="19" r="3"></circle>
								<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
								<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
							</svg>
						</button>
					</div>
				</div>

				<div class="stock-price-section">
					<div class="price-info">
						<span class="price-val">${stock.price}</span>
						<span class={`price-change ${stock.isPositive ? 'positive' : 'negative'}`}>
							{stock.change} ({stock.changePercent})
						</span>
					</div>
					<div class="price-time">{stock.time}</div>
					<div class="sparkline-wrapper">
						<svg class="header-sparkline" viewBox="0 0 100 30">
							<path d={stock.sparkline} fill="none" stroke={stock.isPositive ? 'var(--positive)' : 'var(--negative)'} stroke-width="2" stroke-linecap="round"/>
						</svg>
					</div>
				</div>
			</div>

			<!-- Tabs Navigation -->
			<div class="stock-tabs-container">
				<div class="stock-tabs">
					<a href="#" class="tab-link active">概要</a>
					<a href="#articles" class="tab-link">分析記事</a>
					<a href="#videos" class="tab-link">動画</a>
					<a href="#earnings" class="tab-link">決算</a>
					<a href="#financials" class="tab-link">財務指標</a>
					<a href="#news" class="tab-link">ニュース</a>
					<a href="#chart" class="tab-link">チャート</a>
					<a href="#related" class="tab-link">関連銘柄</a>
				</div>
			</div>

			<!-- Three-Column Details Grid -->
			<div class="details-grid">
				<!-- Column 1: AI Score & Radar Chart -->
				<div class="glass-card details-column-card">
					<h3 class="column-card-title">AIスコア</h3>
					<div class="ai-score-summary">
						<span class="ai-score-number">{stock.aiScore} <span class="score-base">/ 100</span></span>
						<span class="ai-score-label badge badge-positive">{stock.aiVerdict}</span>
					</div>
					
					<!-- Radar Chart SVG Container -->
					<div class="radar-chart-container">
						<svg class="radar-chart-svg" viewBox="0 0 100 100">
							<!-- Concentric Grid Pentagons -->
							<polygon points="50,15 88,43 74,88 26,88 12,43" fill="none" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<polygon points="50,26.5 75.3,45.3 66,75.3 34,75.3 24.7,45.3" fill="none" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<polygon points="50,38 62.7,47.7 58,62.7 42,62.7 37.3,47.7" fill="none" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							
							<!-- Grid Axis Lines -->
							<line x1="50" y1="50" x2="50" y2="15" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<line x1="50" y1="50" x2="88" y2="43" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<line x1="50" y1="50" x2="74" y2="88" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<line x1="50" y1="50" x2="26" y2="88" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>
							<line x1="50" y1="50" x2="12" y2="43" stroke="rgba(255, 255, 255, 0.05)" stroke-width="1"/>

							<!-- Actual Scaled Value Pentagon -->
							<polygon points={radarPoints} fill="rgba(35, 55, 255, 0.25)" stroke="var(--accent-light)" stroke-width="1.5"/>
							
							<!-- Labels on Axis -->
							<text x="50" y="10" text-anchor="middle" font-size="5.5" fill="var(--text-secondary)" font-weight="600">成長性</text>
							<text x="91" y="44" text-anchor="start" font-size="5.5" fill="var(--text-secondary)" font-weight="600">収益性</text>
							<text x="76" y="93" text-anchor="start" font-size="5.5" fill="var(--text-secondary)" font-weight="600">モメンタム</text>
							<text x="24" y="93" text-anchor="end" font-size="5.5" fill="var(--text-secondary)" font-weight="600">割安性</text>
							<text x="9" y="44" text-anchor="end" font-size="5.5" fill="var(--text-secondary)" font-weight="600">財務健全性</text>
						</svg>
					</div>
					<div class="score-action-box">
						<a href="#scores" class="score-detail-link">スコアの詳細を見る &gt;</a>
					</div>
				</div>

				<!-- Column 2: 企業概要 (Company Overview) -->
				<div class="glass-card details-column-card">
					<h3 class="column-card-title">企業概要</h3>
					<p class="company-desc">{stock.overview}</p>
					
					<div class="company-info-table">
						<div class="info-row">
							<span class="info-label">設立</span>
							<span class="info-value">{stock.founded}</span>
						</div>
						<div class="info-row">
							<span class="info-label">本社</span>
							<span class="info-value">{stock.hq}</span>
						</div>
						<div class="info-row">
							<span class="info-label">CEO</span>
							<span class="info-value">{stock.ceo}</span>
						</div>
						<div class="info-row">
							<span class="info-label">従業員数</span>
							<span class="info-value">{stock.employees}</span>
						</div>
						<div class="info-row">
							<span class="info-label">公式サイト</span>
							<span class="info-value"><a href={`https://${stock.site}`} target="_blank" class="company-link">{stock.site} ↗</a></span>
						</div>
					</div>
				</div>

				<!-- Column 3: 主要指標 (Key Metrics) -->
				<div class="glass-card details-column-card">
					<h3 class="column-card-title">主要指標</h3>
					
					<div class="metrics-list">
						<div class="metric-row">
							<span class="metric-label">時価総額</span>
							<span class="metric-value">{stock.metrics.mcap}</span>
						</div>
						<div class="metric-row">
							<span class="metric-label">PER (TTM)</span>
							<span class="metric-value">{stock.metrics.per}</span>
						</div>
						<div class="metric-row">
							<span class="metric-label">PBR</span>
							<span class="metric-value">{stock.metrics.pbr}</span>
						</div>
						<div class="metric-row">
							<span class="metric-label">ROE</span>
							<span class="metric-value">{stock.metrics.roe}</span>
						</div>
						<div class="metric-row">
							<span class="metric-label">売上高成長率 (YoY)</span>
							<span class="metric-value positive">{stock.metrics.revGrowth}</span>
						</div>
						<div class="metric-row">
							<span class="metric-label">純利益率</span>
							<span class="metric-value positive">{stock.metrics.netMargin}</span>
						</div>
					</div>
					<div class="metrics-action-box">
						<a href="#metrics" class="metrics-detail-link">財務指標をもっと見る &gt;</a>
					</div>
				</div>
			</div>

			<!-- Related Content (Videos & Articles) -->
			<div class="related-content-section" id="videos">
				<div class="section-header">
					<h2 class="section-title">関連動画</h2>
					<a href="/#videos" class="view-all-link">すべて見る &gt;</a>
				</div>
				<div class="videos-grid">
					{stock.videos.map(video => (
						<div class="glass-card video-card">
							<!-- Custom Video Thumbnail Placeholder -->
							<div class="video-thumbnail-placeholder">
								<div class="video-play-btn">
									<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</div>
								<span class="video-duration">{video.duration}</span>
							</div>
							<div class="video-info">
								<h4 class="video-title">{video.title}</h4>
								<div class="video-meta">
									<span class="video-author">TechMoney</span>
									<span class="video-views-date">{video.views} ｜ {video.date}</span>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="related-content-section" id="articles">
				<div class="section-header">
					<h2 class="section-title">関連記事</h2>
					<a href="/" class="view-all-link">すべて見る &gt;</a>
				</div>
				<div class="articles-grid">
					{displayedPosts.map(post => (
						<article class="glass-card article-card-small">
							<a href={`/blog/${post.id}/`} class="article-link-small">
								<div class="article-meta-small">
									<span class="badge badge-positive">企業分析</span>
									<time class="article-date-small">
										{post.data.pubDate.toLocaleDateString('ja-JP', {
											year: 'numeric',
											month: '2-digit',
											day: '2-digit',
										})}
									</time>
								</div>
								<h4 class="article-title-small">{post.data.title}</h4>
								<p class="article-desc-small">{post.data.description}</p>
								<span class="article-read-link-small">記事を読む &rarr;</span>
							</a>
						</article>
					))}
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	.stock-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}
	.breadcrumb {
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-bottom: 2rem;
	}
	.breadcrumb a {
		color: var(--text-secondary);
	}
	.breadcrumb a:hover {
		color: var(--accent-light);
