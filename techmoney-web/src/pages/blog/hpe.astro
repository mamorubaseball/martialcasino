---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE } from '../../consts';

// Generated from video_summary.html
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <BaseHead title="HPE 投資判断レポート - AIインフラ「オンプレミス回帰」の隠れた勝者 - {SITE_TITLE}" description="オンプレミスAI回帰で急浮上するHPEの強み、ジュニパー買収効果、バリュエーションを分析。" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  <style is:global>

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap');

  :root {
    --bg-primary: #0B132B;
    --bg-secondary: #1C2541;
    --border-color: rgba(16, 185, 129, 0.15);
    --text-primary: #f1f5f9;
    --text-secondary: #cbd5e1;
    --text-muted: #64748b;
    --color-accent: #10B981; /* Investment Green */
    --color-secondary: #F59E0B; /* Gold */
    --color-danger: #EF4444; /* Bear Red */
    --gradient-primary: linear-gradient(135deg, #10B981 0%, #34D399 50%, #3b82f6 100%);
    --font-sans: 'Inter', 'Noto Sans JP', sans-serif;
    --font-mono: 'Courier New', 'Roboto Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.8;
    font-size: 15px;
  }

  /* ── Header ── */
  .header {
    background: linear-gradient(135deg, #1c2541 0%, #0b132b 100%);
    border-bottom: 2px solid var(--border-color);
    padding: 60px 40px 40px;
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  
  .ticker-badge {
    font-family: var(--font-mono);
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: bold;
    display: inline-block;
    margin-bottom: 15px;
  }

  h1 {
    font-size: 32px;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 18px;
    max-width: 800px;
    margin: 0 auto 30px;
  }

  /* ── Main Layout ── */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  /* ── Metrics Grid ── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .metric-card {
    background: rgba(28, 37, 65, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 25px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .metric-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(16, 185, 129, 0.1);
    border-color: var(--color-accent);
  }

  .metric-label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .metric-value {
    font-size: 36px;
    font-weight: 900;
    font-family: var(--font-mono);
    color: var(--color-accent);
  }

  .metric-value.gold {
    color: var(--color-secondary);
  }

  .metric-subtext {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 5px;
  }

  /* ── Content Grid ── */
  .content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
  }

  .main-column {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .card {
    background: rgba(28, 37, 65, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 30px;
    backdrop-filter: blur(10px);
  }

  .card-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card-title::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 18px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  p {
    margin-bottom: 15px;
    color: var(--text-secondary);
  }

  ul, ol {
    margin-left: 20px;
    margin-bottom: 15px;
    color: var(--text-secondary);
  }

  li {
    margin-bottom: 8px;
  }

  .highlight {
    color: var(--color-accent);
    font-weight: bold;
  }

  /* ── Sidebar ── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .status-box {
    background: rgba(16, 185, 129, 0.05);
    border: 1px solid var(--color-accent);
    border-radius: 8px;
    padding: 25px;
    text-align: center;
  }

  .status-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 10px;
  }

  .status-value {
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 15px;
  }

  .analyst-card {
    background: rgba(28, 37, 65, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 25px;
  }

  .analyst-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 14px;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
    padding-bottom: 8px;
  }

  .analyst-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .analyst-label {
    color: var(--text-muted);
  }

  .analyst-value {
    font-weight: bold;
    font-family: var(--font-mono);
  }

  /* ── Versus Table ── */
  .vs-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
  }

  .vs-table th, .vs-table td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .vs-table th {
    color: var(--text-muted);
    font-size: 12px;
    text-transform: uppercase;
  }

  .vs-table td.hpe-col {
    color: var(--color-accent);
    font-weight: bold;
  }

  /* ── Risk List ── */
  .risk-item {
    border-left: 3px solid var(--color-danger);
    background: rgba(239, 68, 68, 0.03);
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 0 8px 8px 0;
  }

  .risk-title {
    font-weight: bold;
    color: var(--text-primary);
    margin-bottom: 5px;
  }

  .risk-desc {
    font-size: 13px;
    color: var(--text-secondary);
  }


    /* Unified Layout Styles */
    .blog-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }
    .breadcrumb {
        font-size: 0.85rem;
        color: var(--text-secondary, #cbd5e1);
        margin-bottom: 2rem;
    }
    .breadcrumb a {
        color: var(--text-secondary, #cbd5e1);
        text-decoration: none;
    }
    .breadcrumb a:hover {
        color: var(--color-accent, #10B981);
    }
    .breadcrumb .separator {
        margin: 0 0.5rem;
        color: var(--text-muted, #64748b);
    }
    .article-content {
        display: flex;
        gap: 3rem;
        align-items: flex-start;
        margin-top: 2rem;
    }
    .toc-sidebar {
        width: 280px;
        position: sticky;
        top: 6rem;
        flex-shrink: 0;
    }
    .sidebar-toc {
        background: rgba(28, 37, 65, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        padding: 1.8rem;
        backdrop-filter: blur(10px);
    }
    .sidebar-toc h3 {
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 1.2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-bottom: 0.6rem;
        color: var(--text-primary, #f1f5f9);
    }
    .sidebar-toc ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        margin-left: 0;
        padding-left: 0;
    }
    .sidebar-toc a {
        font-size: 0.9rem;
        color: var(--text-secondary, #cbd5e1);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .sidebar-toc a:hover {
        color: var(--color-accent, #10B981);
    }
    .post-body {
        flex-grow: 1;
        max-width: calc(100% - 310px);
    }
    .anchor-target {
        position: relative;
        top: -100px;
        visibility: hidden;
        display: block;
    }
    .video-container {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        margin-bottom: 2rem;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color, rgba(16, 185, 129, 0.15));
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
    }
    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }
    @media (max-width: 992px) {
        .article-content {
            flex-direction: column;
        }
        .toc-sidebar {
            display: none;
        }
        .post-body {
            max-width: 100%;
        }
    }
  </style>
</head>
<body>
  <Header />
  
  <main class="blog-main">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">← ホームに戻る</a>
        <span class="separator">|</span>
        <a href="/">トップ</a> &gt; <a href="/blog">ブログ</a> &gt; <span class="current">HPE 投資判断レポート - AIインフラ「オンプレミス回帰」の隠れた勝者</span>
      </div>
    </div>
    
    <div class="header">
  <span class="ticker-badge">NYSE: HPE</span>
  <h1>ヒューレット・パッカード・エンタープライズ 投資判断レポート</h1>
  <p class="subtitle">AIインフラ「オンプレミス回帰」のメガトレンドを牽引する隠れた本命割安株</p>
</div>

<div class="container">

  <div class="video-container">
    <iframe src="https://www.youtube.com/embed/3JMaU-o66sw" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
  </div>
  
  <!-- Metrics Dashboard -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-label">株価 (現在値)</div>
      <div class="metric-value font-mono">~$47.0</div>
      <div class="metric-subtext">2026年6月中旬時点</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">予想PER (割安度)</div>
      <div class="metric-value font-mono">~14x</div>
      <div class="metric-subtext">AIセクター内で極めて割安</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">Q2売上成長率</div>
      <div class="metric-value font-mono">YoY +40%</div>
      <div class="metric-subtext">売上高：$10.68B (市場予想超過)</div>
    </div>
    <div class="metric-card">
      <div class="metric-label">NW部門成長率</div>
      <div class="metric-value font-mono gold">YoY +152%</div>
      <div class="metric-subtext">ジュニパー統合のシナジー炸裂</div>
    </div>
  </div>

  
  <div class="article-content">
    <aside class="toc-sidebar">
      <div class="glass-card sidebar-toc">
        <h3>目次</h3>
        <ul>
          <li><a href="#chapter-1">メガトレンド：AIサーバーの「オンプレミス回帰」</a></li>
          <li><a href="#chapter-2">競合比較：Dell（ボリューム重視） vs HPE（利益率・質重視）</a></li>
          <li><a href="#chapter-3">HPE独自のコア強み</a></li>
          <li><a href="#chapter-4">直近業績（2026年Q2）と通期見通し</a></li>
          <li><a href="#chapter-5">バリュエーション指標</a></li>
          <li><a href="#chapter-6">主な懸念点・リスク</a></li>
        </ul>
      </div>
    </aside>
    <div class="post-body">
      <div class="content-grid">
    <!-- Main Column -->
    <div class="main-column">
      <!-- Section 1: Megatrend -->
      <div class="card">
        <div id="chapter-1" class="anchor-target"></div><div class="card-title">メガトレンド：AIサーバーの「オンプレミス回帰」</div>
        <p>ゴールドマン・サックスがHPEを強力にプッシュする背景には、<span class="highlight">「AIサーバーのオンプレミス回帰」</span>という強固なトレンドがあります。</p>
        <p>セキュリティと情報漏洩対策を最重視する企業群が、機密データや個人情報をAIに学習させる目的で、パブリッククラウドから自社運用（オンプレミス）サーバーへと回帰しています。このインフラ需要をダイレクトに掴むのが、高性能サーバーの老舗であるHPEです。</p>
      </div>

      <!-- Section 2: Competitive Strategy -->
      <div class="card">
        <div id="chapter-2" class="anchor-target"></div><div class="card-title">競合比較：Dell（ボリューム重視） vs HPE（利益率・質重視）</div>
        <p>AIサーバーシェア首位のデル・テクノロジーズに対し、HPEは明確な差別化戦略をとっています。</p>
        <table class="vs-table">
          <thead>
            <tr>
              <th>項目</th>
              <th>デル・テクノロジーズ (DELL)</th>
              <th class="hpe-col">HPE (HPE)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>戦略方針</td>
              <td>ボリューム・販売台数重視</td>
              <td class="hpe-col">質・付加価値・高利益率重視</td>
            </tr>
            <tr>
              <td>差別化要因</td>
              <td>大規模販売・価格競争</td>
              <td class="hpe-col">ネットワーク統合 ＋ サブスク（GreenLake）</td>
            </tr>
            <tr>
              <td>利益率動向</td>
              <td>価格競争による圧迫リスクあり</td>
              <td class="hpe-col">ジュニパー買収効果で高い水準を維持</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Section 3: Strength -->
      <div class="card">
        <div id="chapter-3" class="anchor-target"></div><div class="card-title">HPE独自のコア強み</div>
        <ul>
          <li><span class="highlight">サーバーとネットワークの垂直統合：</span>
            通信ネットワーク大手「ジュニパーネットワークス」を買収・統合したことで、AIの頭脳（サーバー）と神経網（ネットワーク機器）を一体化したソリューションとして一括提供可能に。
          </li>
          <li><span class="highlight">従量課金サブスクモデル「GreenLake」：</span>
            初期費用を数億円かけることなく、使用した分だけ支払うハードウェアのサブスク型サービス。顧客は導入ハードルが下がり、HPEは極めて安定した月額リピート収益を獲得できるビジネスモデル。
          </li>
        </ul>
      </div>

      <!-- Section 4: Latest Earnings -->
      <div class="card">
        <div id="chapter-4" class="anchor-target"></div><div class="card-title">直近業績（2026年Q2）と通期見通し</div>
        <p>Q2決算では売上高106億8,000万ドル（YoY +40%）を記録し、市場予想を大幅に超える実績を残しました。</p>
        <p>特にジュニパーネットワークスの統合シナジーを受けたネットワーク部門の売上は、前年比<span class="highlight">152%超の暴増</span>を記録。通期の売上成長率予測も当初の17-22%から<span class="highlight">29-33%へ大幅に上方修正</span>し、2028年度の経営目標を約2年半前倒しで達成する勢いを見せています。</p>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Status Box -->
      <div class="status-box">
        <div class="status-title">総合投資判断</div>
        <div class="status-value">「 買 い 」</div>
        <p style="font-size: 13px; margin-bottom: 0;">保有期間の目安：1〜3年間の中長期投資に最適。ポートフォリオの成長株枠として推奨。</p>
      </div>

      <!-- Valuation Box -->
      <div class="analyst-card">
        <div id="chapter-5" class="anchor-target"></div><div class="card-title" style="font-size: 16px; margin-bottom: 15px;">バリュエーション指標</div>
        <div class="analyst-row">
          <span class="analyst-label">時価総額</span>
          <span class="analyst-value">~$63.0B</span>
        </div>
        <div class="analyst-row">
          <span class="analyst-label">目標株価 (中央値)</span>
          <span class="analyst-value">$60 - $67</span>
        </div>
        <div class="analyst-row">
          <span class="analyst-label">目標株価 (強気上限)</span>
          <span class="analyst-value" style="color: var(--color-accent);">$80</span>
        </div>
        <div class="analyst-row">
          <span class="analyst-label">配当利回り</span>
          <span class="analyst-value">1.0% - 1.2%</span>
        </div>
      </div>

      <!-- Risks Box -->
      <div class="analyst-card">
        <div id="chapter-6" class="anchor-target"></div><div class="card-title" style="font-size: 16px; margin-bottom: 15px; color: var(--color-danger); border-bottom-color: rgba(239, 68, 68, 0.1);">主な懸念点・リスク</div>
        
        <div class="risk-item">
          <div class="risk-title">GPUなどの部材価格高騰</div>
          <div class="risk-desc">AIサーバーに不可欠なNVIDIA製GPUなどの仕入れコスト高騰により、利益率が圧迫され、業績が下方修正されるリスク。</div>
        </div>

        <div class="risk-item">
          <div class="risk-title">メガクラウドの類似サービス展開</div>
          <div class="risk-desc">GoogleやAnthropicなどのクラウド巨人が、オンプレミスに匹敵する高セキュリティでカスタマイズ可能なサービスを安価に提供し始めた場合の競争激化。</div>
        </div>

        <div class="risk-item">
          <div class="risk-title">景気悪化に伴うIT投資抑制</div>
          <div class="risk-desc">世界的なマクロ経済悪化に伴い、一般企業が設備投資やITインフラ更新のバジェットを一時的に削減するリスク。</div>
        </div>
      </div>
    </div>
    </div>
  </div>
</div>
  </main>

  <Footer />
</body>
</html>
