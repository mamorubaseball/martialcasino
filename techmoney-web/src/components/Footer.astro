---
const today = new Date();
---

<footer class="footer">
	<div class="footer-content">
		<div class="footer-info">
			<span class="footer-logo">TechMoney</span>
			<p class="footer-desc">テクノロジーとデータを軸にした米国株分析プラットフォーム</p>
		</div>
		<div class="footer-links">
			<a href="/">トップ</a>
			<a href="/stock">銘柄一覧</a>
			<a href="/ranking/ai">ランキング</a>
			<a href="/about">ABOUT</a>
		</div>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} TechMoney / AntigravityCompany. All rights reserved.
	</div>
</footer>

<style>
	.footer {
		background: rgba(7, 9, 14, 0.9);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding: 3rem 1.5rem 2rem 1.5rem;
		margin-top: 4rem;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 2rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.footer-info {
		max-width: 300px;
	}
	.footer-logo {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 800;
		color: #ffffff;
		letter-spacing: -0.02em;
		display: block;
		margin-bottom: 0.5rem;
	}
	.footer-desc {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}
	.footer-links {
		display: flex;
		gap: 2rem;
	}
	.footer-links a {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}
	.footer-links a:hover {
		color: var(--accent-light);
	}
	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 1.5rem;
		text-align: center;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			gap: 1.5rem;
		}
		.footer-links {
			flex-direction: column;
			gap: 0.8rem;
		}
	}
</style>
